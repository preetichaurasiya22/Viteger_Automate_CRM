<!--
    cbt.xml — Cross Browser Testing (CBT)
    Each <test> block runs on a different browser via @Parameters("bro").
    
    parallel="tests" → each <test> block runs in a separate thread simultaneously
    
    FIX: OrgTest was ignoring the 'bro' parameter (used hardcoded 'chrome').
         That bug is now fixed in OrgTest.java.
-->
<suite parallel="tests" thread-count="3" name="CrossBrowser_Suite">

    <listeners>
        <listener class-name="listeners_utility.List_Imp" />
    </listeners>

    <test name="Chrome_Test">
        <parameter name="bro" value="chrome" />
        <classes>
            <class name="types_of_execution.OrgTest" />
        </classes>
    </test>

    <test name="Edge_Test">
        <parameter name="bro" value="edge" />
        <classes>
            <class name="types_of_execution.ContactTest" />
        </classes>
    </test>

    <test name="Firefox_Test">
        <parameter name="bro" value="firefox" />
        <classes>
            <class name="types_of_execution.LeadTest" />
        </classes>
    </test>

</suite>
